# Secrets / config — never commit
.env

# The archive: sensitive third-party exposure data, large, irreplaceable.
# Keep it out of git entirely. Back it up out-of-band instead.
daily_downloads/

# Python virtualenv (rebuildable from requirements.txt)
venv/
__pycache__/
*.pyc

# Generated triage reports — list named orgs and their weaknesses (FOUO).
reports/
# Refreshable public enrichment caches (KEV/EPSS) — not worth versioning.
reference/
# Derived analytical store (Parquet + DuckDB) — rebuildable from daily_downloads,
# and contains the same sensitive named-org data. Never commit.
store/

# Logs
*.log

# Any stray Shodan credential files
*api_key*
.config/

# MaxMind GeoIP databases (licensed, large)
*.mmdb
geoip*.tar.gz
