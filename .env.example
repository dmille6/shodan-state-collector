# =============================================================================
# shodan_query — configuration
# =============================================================================
# Copy this file to ".env" and edit the values below:
#     cp .env.example .env
#
# ".env" is gitignored and must NEVER be committed. The Shodan API key is NOT
# stored here — it lives at ~/.config/shodan/api_key (set via `shodan init`).
# =============================================================================

# Two-letter region/state code used in the Shodan query (state:<CODE>).
# This is a Shodan region code, NOT a full name. e.g. LA, TX, NY, CA.
# This is the value that actually drives WHICH state's hosts are downloaded.
SHODAN_STATE_CODE=LA

# Human-readable state name, used only for output FILENAMES:
#     <SHODAN_STATE_NAME>-events-YYYY-MM-DD.json.gz
# Keep it lowercase, no spaces (e.g. louisiana, texas, new_york).
SHODAN_STATE_NAME=louisiana

# Run a second, supplemental "org-rescue" query to catch hosts owned by orgs
# named after the state but hosted OUTSIDE it (e.g. in cloud ranges that
# geolocate to another state). Results are merged + deduped into the same file.
#   true  = also run  org:<SHODAN_ORG_NAME> -state:<SHODAN_STATE_CODE>
#   false = geo query only
# NOTE: this is most useful for states whose name appears in org names
# (e.g. "Louisiana"). For other states it can add noise — set false if so.
SHODAN_ORG_RESCUE=true

# Search term for the org-rescue query above. Defaults to SHODAN_STATE_NAME if
# left blank/unset. Override if the org keyword differs from the filename name.
SHODAN_ORG_NAME=louisiana

# Subfolder (relative to this project) where daily archives are written.
OUTPUT_DIR=daily_downloads

# Delete archives older than this many days. 0 = keep forever (recommended:
# this archive is the only longitudinal record and cannot be re-downloaded).
RETENTION_DAYS=0

# Path to the virtualenv that holds the `shodan` CLI. Defaults to ./venv next
# to this script; only change it if your venv lives elsewhere.
# VENV_DIR=/opt/shodan_query/venv
