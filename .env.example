# =============================================================================
# shodan_query — configuration
# =============================================================================
# Copy this file to ".env" and edit the values below:
#     cp .env.example .env
#
# ".env" is gitignored and must NEVER be committed. The Shodan API key is NOT
# stored here — it lives at ~/.config/shodan/api_key (set via `shodan init`).
# =============================================================================

# Two-letter region/state code used in the Shodan query (state:<CODE>).
# This is a Shodan region code, NOT a full name. e.g. LA, TX, NY, CA.
# This is the value that actually drives WHICH state's hosts are downloaded.
SHODAN_STATE_CODE=LA

# Human-readable state name, used only for output FILENAMES:
#     <SHODAN_STATE_NAME>-events-YYYY-MM-DD.json.gz
# Keep it lowercase, no spaces (e.g. louisiana, texas, new_york).
SHODAN_STATE_NAME=louisiana

# Run a second, supplemental "org-rescue" query to catch hosts owned by orgs
# named after the state but hosted OUTSIDE it (e.g. in cloud ranges that
# geolocate to another state). Results are merged + deduped into the same file.
#   true  = also run  org:<SHODAN_ORG_NAME> -state:<SHODAN_STATE_CODE>
#   false = geo query only
# NOTE: this is most useful for states whose name appears in org names
# (e.g. "Louisiana"). For other states it can add noise — set false if so.
SHODAN_ORG_RESCUE=true

# Search term for the org-rescue query above. Defaults to SHODAN_STATE_NAME if
# left blank/unset. Override if the org keyword differs from the filename name.
SHODAN_ORG_NAME=louisiana

# Subfolder (relative to this project) where daily archives are written.
OUTPUT_DIR=daily_downloads

# Delete archives older than this many days. 0 = keep forever (recommended:
# this archive is the only longitudinal record and cannot be re-downloaded).
RETENTION_DAYS=0

# Path to the virtualenv that holds the `shodan` CLI. Defaults to ./venv next
# to this script; only change it if your venv lives elsewhere.
# VENV_DIR=/opt/shodan_query/venv

# --- Partial-download protection -------------------------------------------
# Shodan sometimes drops a download mid-stream and saves only part of the
# results while still exiting cleanly. The collector compares the saved record
# count against a free `shodan count` and retries when it comes back short.

# How many times to attempt each query's download before giving up.
MAX_DOWNLOAD_ATTEMPTS=3

# A download counts as "complete" when saved >= this percent of the count.
# (Counts fluctuate slightly and a few hosts always drop between count and
# download, so 90 is a safe threshold — not 100.)
MIN_COMPLETENESS_PCT=90

# Seconds to wait between download retries (bash collector); also the base for
# exponential backoff on a failed page (Python collector: 30 -> 60 -> 120).
RETRY_SLEEP=30

# Python collector only: seconds to pause between result pages.
# IMPORTANT: keep this 0. Shodan maintains a server-side cursor for deep
# pagination that TIMES OUT if you page too slowly — a pause caps big days at
# ~10k results (page ~100). 0 = paginate at API speed, like the CLI. Only raise
# it if you actually see throttling, and know it will break very deep pulls.
PAGE_PAUSE_SECONDS=0

# MaxMind City DB for independent geolocation (drop a *.mmdb in reference/).
# If unset, the first reference/*.mmdb is auto-detected. Without any DB, the
# collector/store fall back to the banner's own region_code. City edition only.
# GEOIP_DB=/opt/shodan_query/reference/GeoLite2-City.mmdb

# Collect the primary query via CIDR-bisection sharding — recursively splits the
# IP-address space so each sub-query stays small and paginates shallowly, avoiding
# Shodan's deep-cursor timeouts on big days. Provably complete (partitions the
# whole address space). off | on. Also togglable per-run with --shard.
SHARD_MODE=off
# Max results per shard before it's split further (keep well under the page where
# the cursor starts timing out, ~5k on bad nights).
SHARD_THRESHOLD=4000

# --- Compromise tripwire (compromise_watch.py) -----------------------------
# The main collector pulls the whole exposure census (exposed + vulnerable). The
# tripwire complements it by asking Shodan specifically for hosts it has FLAGGED
# as compromised/malicious in this state — a normally-silent, high-signal alert.
# Each selector is sized with a FREE `shodan count`; a paid search runs only when
# the count is > 0, so a quiet day costs zero query credits.

# Shodan THREAT TAGS to check, comma-separated (query: state:<CODE> tag:<tag>).
# Unknown tags simply return 0 — safe to add speculative ones.
COMPROMISE_TAGS=compromised,malware,c2,botnet

# Shodan CATEGORIES to check, comma-separated (query: state:<CODE> category:<cat>).
COMPROMISE_CATEGORIES=malware

# Extra raw selectors, semicolon-separated, each appended to state:<CODE> country:US.
# Leave blank unless you have a specific hunt (e.g. "vuln:CVE-2024-3400").
COMPROMISE_EXTRA_QUERIES=
